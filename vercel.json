{
  "headers": [
    {
      "source": "/blog/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/index\\.(jsp|htm|html|asp|aspx|php|cgi)",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/en/index\\.(jsp|htm|html|asp|aspx|php|cgi)",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "ainchina.com"
        }
      ],
      "destination": "https://www.ainchina.com/:path*",
      "permanent": true
    }
  ]
}
